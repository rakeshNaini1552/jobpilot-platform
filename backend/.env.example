# JobPilot backend — every knob, with defaults. Copy to .env and edit.
# All variables are prefixed JOBPILOT_.

JOBPILOT_ENV=local                       # local | docker | prod
JOBPILOT_DATABASE_URL=postgresql+psycopg://jobpilot:jobpilot@localhost:5432/jobpilot
JOBPILOT_REDIS_URL=redis://localhost:6379/0
JOBPILOT_CORS_ORIGINS=["http://localhost:5173"]

# --- security (REQUIRED in prod: generate long random values) ---
JOBPILOT_JWT_SECRET=dev-only-change-me
JOBPILOT_MASTER_KEY=dev-only-master-key-32-bytes!!

# --- AI providers (ALL optional; chain skips unconfigured ones) ---
JOBPILOT_AI_PROVIDER_CHAIN=["OLLAMA","OPENROUTER","GEMINI","ANTHROPIC","OPENAI"]
JOBPILOT_OLLAMA_BASE_URL=http://localhost:11434
JOBPILOT_OPENROUTER_API_KEY=
JOBPILOT_GEMINI_API_KEY=
JOBPILOT_ANTHROPIC_API_KEY=
JOBPILOT_OPENAI_API_KEY=
JOBPILOT_AI_DAILY_TOKEN_BUDGET=500000

# --- email (optional; daily reports skip silently if unset) ---
JOBPILOT_SMTP_HOST=
JOBPILOT_SMTP_PORT=465
JOBPILOT_SMTP_USER=
JOBPILOT_SMTP_PASSWORD=
JOBPILOT_SMTP_FROM=jobpilot@localhost

JOBPILOT_DEFAULT_TIMEZONE=America/Chicago
JOBPILOT_LOG_JSON=false
